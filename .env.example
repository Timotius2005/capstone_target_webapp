# ─────────────────────────────────────────────────────────────────────────────
# PT. Dana Sejahtera — Docker Compose Environment
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values, then:
#   docker compose up --build
#
# NEVER commit the real .env — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────────────────────────
# These must match POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB in docker-compose.
DB_USER=fintech
DB_PASSWORD=securepass
DB_NAME=nasabahdb

# ─── JWT secret ───────────────────────────────────────────────────────────────
# Must be at least 32 random characters in any real deployment.
JWT_SECRET=change-me-in-production-min-32-chars!!

# ─── Security mode ────────────────────────────────────────────────────────────
# "secure"     → all OWASP protections active  (default, use for demos)
# "vulnerable" → sandbox mode, intentional weaknesses exposed (CTF / pentest)
# Can be toggled at runtime via the /api/system/mode endpoint — no restart needed.
APP_SECURITY_MODE=secure

# ─── Optional lab access key ─────────────────────────────────────────────────
# When set, every call to /api/system/* must include: X-LAB-KEY: <value>
# Leave empty to allow unauthenticated access to the mode-switch endpoint.
LAB_KEY=
