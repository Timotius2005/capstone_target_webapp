# ─── Go ──────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Compiled binaries (CI builds these at runtime)
backend/bin/

# ─── Node.js / Next.js ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.next/
out/

# ─── Environment variables (NEVER commit real credentials) ───────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
# Keep .env.local.example — it is a template, no secrets
!frontend/.env.local.example

# ─── Playwright ──────────────────────────────────────────────────────────────
# Saved browser auth states contain live JWT tokens — never commit
frontend/e2e/.auth/

# E2E run artefacts
frontend/playwright-report/
frontend/test-results/

# ─── CI / Test reports (generated; uploaded as workflow artefacts instead) ───
# Allow the sentinel file that keeps the directory tracked in git
reports/*
!reports/.gitkeep

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Database ────────────────────────────────────────────────────────────────
*.db
*.sqlite

# ─── Docker ──────────────────────────────────────────────────────────────────
.dockerignore
