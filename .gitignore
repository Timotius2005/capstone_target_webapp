# ─── Go ──────────────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
go.work
go.work.sum

# Compiled binaries
backend/bin/
backend/server

# ─── Node.js / Next.js ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp
.pnp.js

# Next.js build output
.next/
out/
frontend/.next/
frontend/out/

# TypeScript build cache
tsconfig.tsbuildinfo
*.tsbuildinfo

# ─── Environment variables (NEVER commit real credentials) ───────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
# Keep example templates — they contain no secrets
!.env.example
!backend/.env.example
!frontend/.env.local.example

# ─── Playwright ──────────────────────────────────────────────────────────────
# Auth state files contain live JWT tokens — never commit
frontend/e2e/.auth/
frontend/playwright-report/
frontend/test-results/

# ─── CI / Test reports ───────────────────────────────────────────────────────
reports/*
!reports/.gitkeep

# ─── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ─── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── Logs ────────────────────────────────────────────────────────────────────
logs/
*.log

# ─── Database ────────────────────────────────────────────────────────────────
*.db
*.sqlite

# ─── Docker (local overrides only — Dockerfiles and compose are committed) ───
# .dockerignore files are NOT ignored — they belong in the repo
docker-compose.override.yml
