# ─── PT. Dana Sejahtera — Backend Environment ────────────────────────────────

# Server
PORT=8080

# Security mode: "secure" (default) | "vulnerable"
# secure     → all OWASP protections enabled
# vulnerable → intentional vulnerability injection for demo/CTF
APP_SECURITY_MODE=secure

# Database (matches docker-compose postgres service)
DATABASE_URL=host=postgres user=fintech password=securepass dbname=nasabahdb port=5432 sslmode=disable

# JWT secret — must be at least 32 chars in production
JWT_SECRET=change-me-in-production-min-32-chars-long!

# Runtime environment
ENVIRONMENT=development

# ─── Docker-compose overrides (used internally) ───────────────────────────────
# POSTGRES_USER=fintech
# POSTGRES_PASSWORD=securepass
# POSTGRES_DB=nasabahdb
