# ─────────────────────────────────────────────────────────────────────────────
# PT. Dana Sejahtera — Backend Environment (local dev / outside Docker)
#
# For Docker Compose, env vars are injected by docker-compose.yml — you do not
# need this file inside the container.
#
# For local development:
#   cp backend/.env.example backend/.env
#   # Edit values, then: cd backend && go run ./cmd
# ─────────────────────────────────────────────────────────────────────────────

# Server
PORT=8080

# Security mode: "secure" (default) | "vulnerable" (CTF/pentest only)
APP_SECURITY_MODE=secure

# ─── Database ─────────────────────────────────────────────────────────────────
# Use the same values as docker-compose.yml when running against the local DB container.
DB_HOST=localhost
DB_PORT=5432
DB_USER=fintech
DB_PASSWORD=securepass
DB_NAME=nasabahdb
DB_SSLMODE=disable

# ─── JWT secret ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production-min-32-chars!!

# Runtime environment
ENVIRONMENT=development

# Lab key (optional) — leave empty to allow unauthenticated /api/system/* access
LAB_KEY=
